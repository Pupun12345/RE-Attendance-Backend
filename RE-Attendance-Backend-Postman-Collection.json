{
  "info": {
    "name": "RE-Attendance Backend API",
    "description": "Comprehensive API collection for SmartCare RE Attendance Backend system",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000/api/v1"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Setup",
      "item": [
        {
          "name": "Create Admin User",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/setup/admin",
              "host": ["{{baseUrl}}"],
              "path": ["setup", "admin"]
            },
            "description": "Creates the default admin user with credentials: admin@example.com / password123"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.to.have.status(200)) {",
                  "    const response = pm.response.json();",
                  "    if (response.success && response.token) {",
                  "        pm.collectionVariables.set('token', response.token);",
                  "    }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"admin@example.com\",\n    \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            },
            "description": "Login with email/password. Token is auto-saved to collection variables."
          },
          "response": []
        },
        {
          "name": "Forgot Password",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"admin@example.com\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/forgotpassword",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "forgotpassword"]
            },
            "description": "Send password reset email (currently not implemented)"
          },
          "response": []
        },
        {
          "name": "Reset Password",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"password\": \"newPassword123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/resetpassword/:token",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "resetpassword", ":token"],
              "variable": [
                {
                  "key": "token",
                  "value": "reset-token-here"
                }
              ]
            },
            "description": "Reset password with token (currently not implemented)"
          },
          "response": []
        }
      ]
    },
